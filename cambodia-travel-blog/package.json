{
  "name": "cambodia-travel-blog",
  "version": "1.0.0",
  "private": true,
  "description": "Wander Khmer - A minimalist Cambodia travel blog",
  "scripts": {
    "build": "npx @tailwindcss/cli -i ./src/css/input.css -o ./src/css/style.css",
